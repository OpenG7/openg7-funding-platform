{
  "name": "openg7-funding-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "yarn@4.9.4",
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "resolutions": {
    "@babel/core": "7.29.7"
  },
  "scripts": {
    "dev": "concurrently \"yarn workspace @openg7/funding-api start\" \"yarn workspace @openg7/funding-web start --proxy-config apps/funding-web/proxy.conf.json\"",
    "dev:funding-web": "yarn workspace @openg7/funding-web start --proxy-config apps/funding-web/proxy.conf.json",
    "dev:api": "yarn workspace @openg7/funding-api start",
    "docker:up": "docker compose up --build",
    "docker:update": "node scripts/docker-update.mjs",
    "docker:down": "docker compose down",
    "db:up": "docker compose --profile database up -d postgres",
    "db:stop": "docker compose --profile database stop postgres",
    "db:logs": "docker compose --profile database logs -f postgres",
    "db:psql": "bash scripts/db-psql.sh",
    "db:migrate": "bash scripts/db-migrate.sh",
    "db:backup": "bash scripts/backup.sh",
    "db:restore": "bash scripts/restore-from-backup.sh",
    "prod:check": "bash scripts/check.sh",
    "prod:deploy": "bash scripts/deploy.sh",
    "prod:backup": "bash scripts/backup.sh",
    "stripe:cli:install": "npm install -g @stripe/cli",
    "stripe:cli:version": "stripe --version",
    "stripe:webhook:listen": "stripe listen --forward-to localhost:3333/api/stripe/webhook",
    "lint": "eslint . --ext .ts,.mts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "yarn build && node --test tests/**/*.test.mjs",
    "test:e2e": "yarn build && node --test tests/funding-sponsorship-e2e-coverage.test.mjs",
    "build": "tsc -p tsconfig.build.json",
    "docs": "typedoc --options typedoc.json"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "concurrently": "9.2.3",
    "cross-env": "^10.0.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.6.2"
  }
}
